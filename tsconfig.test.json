{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["jest", "node"]
  },
  "include": [
    "src/engine/**/*",
    "src/constants/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
